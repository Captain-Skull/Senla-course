<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="010-add-user-id-to-guests" author="George">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="guests" columnName="user_id"/>
            </not>
        </preConditions>

        <addColumn tableName="guests">
            <column name="user_id" type="BIGINT">
                <constraints nullable="true"
                             unique="true"
                             uniqueConstraintName="uq_guests_user_id"/>
            </column>
        </addColumn>

        <addForeignKeyConstraint
                baseTableName="guests"
                baseColumnNames="user_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_guests_user"
                onDelete="SET NULL"/>
    </changeSet>
</databaseChangeLog>